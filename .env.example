# =============================================================================
# binance-oi-square-trader 配置示例
# =============================================================================
# 拷贝为 .env 并填入实际值。**绝不**把 .env 提交到 git。
# =============================================================================

# ===== Runtime Mode (强制) =====
# testnet / mainnet
# 默认 testnet。切换到 mainnet 必须同时设置 TRADER_MAINNET_CONFIRM。
TRADER_MODE=testnet

# 切换到 mainnet 必须同时设置(否则进程立即退出)
# TRADER_MAINNET_CONFIRM=I_UNDERSTAND

# ===== Timezone =====
# 应用层显示和"日界"判断的时区。
# 数据库一律 UTC 存储, 这里只影响 daily reset、TG 告警、Dashboard 展示。
TZ=Asia/Shanghai
DAILY_RESET_TZ=Asia/Shanghai

# ===== Logging =====
# LOG_LEVEL: trace / debug / info / warn / error
# LOG_FORMAT: pretty (dev) / json (prod)
# (Inline comments after KEY=VALUE are NOT stripped by viper's env parser —
#  they would be appended to the value verbatim. Keep comments above lines.)
LOG_LEVEL=info
LOG_FORMAT=pretty

# ===== Binance =====
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Algo Service 迁移日期(系统时间过此日期自动切换条件单接口)
BINANCE_ALGO_MIGRATION_DATE=2025-12-09T00:00:00Z

# ===== Proxy(批量采集币安全部合约时强烈推荐) =====
# 模式: none / single / pool
# - none:   直连(开发期,或 VPS 在已开放区域)
# - single: 所有请求走单一代理
# - pool:   多代理轮换(高强度采集 / 多区域分担)
BINANCE_PROXY_MODE=none

# single 模式: 单个代理 URL, 支持 http(s)://user:pass@host:port 或 socks5://user:pass@host:port
BINANCE_PROXY_URL=

# pool 模式 — 二选一 (PoolFile 优先, 同时设置 PoolURLs 被忽略):
#
# 方式 1 (推荐, 生产 / ≥3 代理): 文件路径,每行一个 URL,# 开头注释,空行跳过
# BINANCE_PROXY_POOL_FILE=./deploy/proxies.txt
#
# 方式 2 (开发 / ≤2 代理): 逗号分隔的多个代理 URL
BINANCE_PROXY_POOL_URLS=
BINANCE_PROXY_POOL_FILE=
# pool 选择策略: round_robin / random
BINANCE_PROXY_POOL_STRATEGY=round_robin
# 单个代理连续失败次数,达到则临时摘除(默认 5)
BINANCE_PROXY_FAILURE_THRESHOLD=5
# 摘除后的恢复尝试间隔(分钟,默认 5)
BINANCE_PROXY_RECOVERY_MINUTES=5

# Square BAPI 是否走代理(通常需要,因为也是 binance.com 域)
SQUARE_USE_PROXY=true

# ===== Database =====
DATABASE_URL=postgres://trader:trader@localhost:5432/trader?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# ===== Telegram =====
TG_BOT_TOKEN=
TG_CHAT_ID=

# ===== Sentry (可选) =====
SENTRY_DSN=

# ===== HTTP Server =====
HTTP_PORT=8080
DASHBOARD_PORT=3000

# ===== Strategy: 监控池 =====
WATCHLIST_MAX_SIZE=150
WATCHLIST_MIN_VOLUME_USD=10000000
WATCHLIST_MIN_LIST_DAYS=7
WATCHLIST_BLACKLIST=USDC,BUSD,TUSD,USDP,UPUSDT,DOWNUSDT,BULLUSDT,BEARUSDT

# ===== Strategy: OI Surge 信号(默认值锚定 contract-monitor.js) =====
OI_SURGE_FROM_LOW_PCT=0.05
OI_SURGE_RECENT_GROWTH_PCT=0.03
OI_SURGE_LOOKBACK_PERIODS=10
OI_SURGE_RECENT_PERIODS=6
OI_SURGE_MIN_GROWING_RATIO=0.5

# ===== Strategy: Square 热度 =====
SQUARE_HOT_MULTIPLIER=2.0
SQUARE_HOT_LOOKBACK_MIN=60
SQUARE_BASELINE_LOOKBACK_HOURS=24

# ===== Strategy: 仓位 =====
MARGIN_PER_TRADE_FULL=50
MARGIN_PER_TRADE_HALF=25
LEVERAGE=10
MAX_CONCURRENT_POSITIONS=5
SAME_SYMBOL_COOLDOWN_HOURS=24

# ===== Strategy: 出场 =====
DISASTER_STOP_PCT=0.06
ATR_PERIOD=14
ATR_TIMEFRAME=15m
SIGNAL_FAIL_OI_DROP_PCT=0.08
SIGNAL_FAIL_PRICE_LOW_BUFFER_PCT=0.03
TP_STAGE1_PCT=0.05
TP_STAGE1_RATIO=0.30
TP_STAGE2_PCT=0.12
TP_STAGE2_RATIO=0.30
TRAILING_ACTIVATE_PCT=0.03
TRAILING_DISTANCE_ATR_MULT=2.0
SOFT_TIMEOUT_HOURS=24
HARD_TIMEOUT_HOURS=72

# ===== Risk Control =====
DAILY_LOSS_HALT_PCT=0.05
CONSECUTIVE_LOSS_HALT_COUNT=5
CONSECUTIVE_LOSS_HALT_HOURS=24
BTC_CRASH_HALT_PCT=0.03
BTC_CRASH_HALT_MINUTES=30
TOTAL_FLOAT_LOSS_HALT_PCT=0.08
API_ERROR_RATE_LIMIT=3

# ===== Square API =====
# 启动时自动生成并写入 Redis: bnc_uuid。下方仅 fallback。
# SQUARE_BNC_UUID=

# ===== Collector concurrency =====
OI_COLLECTOR_CONCURRENCY=8
SQUARE_HASHTAG_CONCURRENCY=10

# Square hashtag 跟踪(T3)失败处理
SQUARE_HASHTAG_TIMEOUT_SECONDS=8
SQUARE_HASHTAG_RETRY_COUNT=2
SQUARE_HASHTAG_RETRY_INTERVAL_MS=1000
SQUARE_HASHTAG_BATCH_DEADLINE_MINUTES=4
